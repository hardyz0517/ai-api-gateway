{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@gateway/core": ["packages/core/src/index.ts"],
      "@gateway/core/*": ["packages/core/src/*"],
      "@gateway/connectors": ["packages/connectors/src/index.ts"],
      "@gateway/connectors/*": ["packages/connectors/src/*"],
      "@gateway/shared": ["packages/shared/src/index.ts"],
      "@gateway/shared/*": ["packages/shared/src/*"]
    }
  }
}
